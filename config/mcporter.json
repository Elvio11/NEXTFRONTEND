{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    },
    "firecrawl": {
      "command": "python",
      "args": ["/app/mcp/firecrawl_mcp.py"]
    },
    "markitdown": {
      "command": "python",
      "args": ["/app/mcp/mcp_server_markitdown.py"] 
    },
    "tavily": {
      "command": "python",
      "args": ["/app/mcp/tavily_mcp.py"] 
    },
    "GoogleSuite": {
      "command": "python",
      "args": ["/app/mcp/google_suite.py"]
    },
    "SupabaseData": {
      "command": "python",
      "args": ["/app/mcp/supabase_data_mcp.py"]
    },
    "supabase": {
      "command": "python",
      "args": ["/app/mcp/supabase_mcp.py"]
    },
    "DocxGenerator": {
      "command": "python",
      "args": ["/app/mcp/docx_generator.py"]
    }
  }
}
